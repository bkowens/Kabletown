# Database Configuration
DB_DSN=kabletown:kabletown_password@tcp(db:3306)/kabletown?parseTime=true&tls=false

# Service Ports
AUTH_SERVICE_PORT=8001
ITEM_SERVICE_PORT=8002
STREAMING_SERVICE_PORT=8003
TRANCODE_SERVICE_PORT=8004
METADATA_SERVICE_PORT=8005
SEARCH_SERVICE_PORT=8006
USER_SERVICE_PORT=8007
COLLECTION_SERVICE_PORT=8008
PLAYLIST_SERVICE_PORT=8009
LIBRARY_SERVICE_PORT=8010
NOTIFICATION_SERVICE_PORT=8011
PLUGIN_SERVICE_PORT=8012

# FFmpeg Configuration
FFMPEG_PATH=/usr/bin/ffmpeg
TRANSCODING_PATH=/tmp/transcoding

# External API Keys (optional)
TMDB_API_KEY=
TVDB_API_KEY=
OMDB_API_KEY=

# Media Paths
MEDIA_PATH=/media
CACHE_PATH=/cache

# Network Configuration
GATEWAY_PORT=8080
